<Window x:Class="service.MainAdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:service"
        mc:Ignorable="d"
        Title="MainAdminWindow" Height="472" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="79*"/>
            <RowDefinition Height="377*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="39*"/>
            <ColumnDefinition Width="161*"/>
        </Grid.ColumnDefinitions>
        <Image Height="71" VerticalAlignment="Top" Margin="6,0,6,0" Source="/diploma.jpg"/>
        <DataGrid x:Name="УслугиDg" IsReadOnly="True" Grid.Column="1" AutoGenerateColumns="False" Margin="0,79,0,106" Grid.RowSpan="2">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Наименование" Binding="{Binding Название_услуги}"/>
                <DataGridTextColumn Header="Категория" Binding="{Binding Категория}"/>
                <DataGridTextColumn Header="Цена услуги" Binding="{Binding Базовая_цена}"/>
                <DataGridTextColumn Header="Время ремонта в мин." Binding="{Binding Среднее_время_мин}"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Margin="0,79,0,0" Grid.RowSpan="2">
            <Button Content="Услуги"/>
            <Button Content="Заявки" Click="MyOrders"/>
        </StackPanel>
        <Button Content="Выход" HorizontalAlignment="Center" Margin="0,298,0,0" Grid.Row="1" VerticalAlignment="Top" Width="136" Click="Home" Height="20"/>
        <Button Grid.Column="1" Content="Добавить/Изменить" HorizontalAlignment="Left" Margin="5,299,0,0" Grid.Row="1" VerticalAlignment="Top" Width="120" Click="AddOrChange"/>
        <Button Grid.Column="1" Content="Удалить" HorizontalAlignment="Left" Margin="546,299,0,0" Grid.Row="1" VerticalAlignment="Top" Width="74" Click="Delete"/>
        <Button Grid.Column="1" Content="Обновить" HorizontalAlignment="Left" Margin="454,299,0,0" Grid.Row="1" VerticalAlignment="Top" Width="74" Click="Reload"/>

    </Grid>
</Window>

