<Window x:Class="service.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:service"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Image HorizontalAlignment="Center" Height="99" Margin="0,28,0,0" VerticalAlignment="Top" Width="128" Source="/diploma.jpg"/>
        <Label Content="Логин" HorizontalAlignment="Left" Margin="336,180,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="Login" HorizontalAlignment="Left" Margin="336,211,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <Label Content="Пароль" HorizontalAlignment="Left" Margin="336,257,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="Password" HorizontalAlignment="Left" Margin="336,288,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <Button Content="Войти" HorizontalAlignment="Left" Margin="336,359,0,0" VerticalAlignment="Top" Width="120" Click="Vxod"/>
        <Button Content="Войти как гость" HorizontalAlignment="Left" Margin="336,384,0,0" VerticalAlignment="Top" Width="120" Click="VxodAsGuest"/>

    </Grid>
</Window>
