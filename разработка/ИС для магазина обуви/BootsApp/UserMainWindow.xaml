<Window x:Class="BootsApp.UserMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BootsApp"
        mc:Ignorable="d"
        Title="UserMainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="83*"/>
            <RowDefinition Height="351*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="89*"/>
            <ColumnDefinition Width="311*"/>
        </Grid.ColumnDefinitions>
        <Image HorizontalAlignment="Left" Height="46" VerticalAlignment="Center" Width="45" Source="/Icon.png" Margin="10,0,0,0"/>
        <Label Content="Магазин Ботинок" HorizontalAlignment="Left" Margin="60,0,0,0" VerticalAlignment="Center" Height="25" Width="112"/>
        <StackPanel Grid.Row="1">
            <Button Content="Товары"/>
        </StackPanel>
        <Button Content="Выход" HorizontalAlignment="Center" Margin="0,306,0,0" Grid.Row="1" Width="158" Click="Button_Click_1" Height="20" VerticalAlignment="Top"/>
        <DataGrid x:Name="DgTovar" Margin="5,83,25,62" Grid.Column="1" AutoGenerateColumns="False" Grid.RowSpan="2">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Фото">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{Binding ImagePath}" Width="50" Height="50"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn  Header="id" Binding="{Binding id}"/>
                <DataGridTextColumn  Header="Наименование товара" Binding="{Binding Наименование_товара}"/>
                <DataGridTextColumn  Header="Единица измерения" Binding="{Binding Единица_измерения}"/>
                <DataGridTextColumn  Header="Цена" Binding="{Binding Цена}"/>
                <DataGridTextColumn  Header="Поставщик" Binding="{Binding Поставщик}"/>
                <DataGridTextColumn  Header="Производитель" Binding="{Binding Производитель}"/>
                <DataGridTextColumn  Header="Категория товара" Binding="{Binding Категория_товара}"/>
                <DataGridTextColumn  Header="Скидка" Binding="{Binding Действующая_скидка}"/>
                <DataGridTextColumn  Header="Кол-во на складе" Binding="{Binding Кол_во_на_складе}"/>
                <DataGridTextColumn  Header="Описание товара" Binding="{Binding Описание_товара}"/>
                <DataGridTextColumn  Header="URL-картинки" Binding="{Binding Фото}"/>
                <DataGridTextColumn  Header="URL-картинки" Binding="{Binding Фото}"/>
            </DataGrid.Columns>
        </DataGrid>
        <Button Grid.Column="1" Content="Купить" HorizontalAlignment="Left" Margin="5,306,0,0" Grid.Row="1" VerticalAlignment="Top" Click="Button_Click" Width="50"/>

    </Grid>
</Window>
