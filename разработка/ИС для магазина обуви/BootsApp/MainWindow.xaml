<Window x:Class="BootsApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BootsApp"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Image HorizontalAlignment="Left" Height="100" Margin="340,29,0,0" VerticalAlignment="Top" Width="100" Source="/Icon.png"/>
        <Label Content="Логин" HorizontalAlignment="Left" Margin="340,155,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="Login" HorizontalAlignment="Center" Margin="0,186,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <Label Content="Пароль" HorizontalAlignment="Left" Margin="340,239,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="Password" HorizontalAlignment="Center" Margin="0,270,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <Button Content="Войти" HorizontalAlignment="Center" Margin="0,340,0,0" VerticalAlignment="Top" Height="22" Width="120" Click="Button_Click_1"/>
        <Button Content="Войти как гость" HorizontalAlignment="Center" Margin="0,379,0,0" VerticalAlignment="Top" Height="22" Width="120" Click="Button_Click"/>

    </Grid>
</Window>
