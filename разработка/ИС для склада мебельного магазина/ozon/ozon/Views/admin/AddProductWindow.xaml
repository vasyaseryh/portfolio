<Window x:Class="ozon.Views.AddProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ozon.Views"
        mc:Ignorable="d"
        Title="Добавление товара" Height="650" Width="550"
        WindowStartupLocation="CenterScreen"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <Border Background="White" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2"/>
        </Border.Effect>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="5">
            <StackPanel Margin="25" TextOptions.TextFormattingMode="Display">

                <!-- Заголовок -->
                <TextBlock Text="Добавление нового товара" 
                           FontSize="22" 
                           FontWeight="SemiBold" 
                           Foreground="#2C3E50"
                           Margin="0,0,0,25"
                           HorizontalAlignment="Center"
                           TextOptions.TextFormattingMode="Display"
                           TextOptions.TextRenderingMode="ClearType"/>

                <!-- Основные поля -->
                <StackPanel Orientation="Vertical">

                    <!-- Название -->
                    <StackPanel>
                        <TextBlock Text="Название товара *" 
                                   FontWeight="SemiBold" 
                                   Foreground="#444"
                                   FontSize="14"
                                   Margin="0,0,0,8"
                                   TextOptions.TextFormattingMode="Display"/>
                        <TextBox x:Name="txtName" 
                                 Height="40" 
                                 Padding="12,8"
                                 FontSize="14"
                                 BorderBrush="#DDD" 
                                 BorderThickness="1.5"
                                 Background="#FAFAFA"
                                 VerticalContentAlignment="Center"
                                 SnapsToDevicePixels="True"/>
                    </StackPanel>

                    <!-- Описание -->
                    <StackPanel>
                        <TextBlock Text="Описание" 
                                   FontWeight="SemiBold" 
                                   Foreground="#444"
                                   FontSize="14"
                                   Margin="0,0,0,8"
                                   TextOptions.TextFormattingMode="Display"/>
                        <TextBox x:Name="txtDescription" 
                                 AcceptsReturn="True" 
                                 TextWrapping="Wrap" 
                                 Height="80"
                                 Padding="12,8"
                                 FontSize="14"
                                 BorderBrush="#DDD" 
                                 BorderThickness="1.5"
                                 Background="#FAFAFA"
                                 VerticalScrollBarVisibility="Auto"
                                 VerticalContentAlignment="Top"/>
                    </StackPanel>

                    <!-- Количество и цена в одной строке -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Количество -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Количество *" 
                                       FontWeight="SemiBold" 
                                       Foreground="#444"
                                       FontSize="14"
                                       Margin="0,0,0,8"
                                       TextOptions.TextFormattingMode="Display"/>
                            <TextBox x:Name="txtQuantity" 
                                     Height="40" 
                                     Padding="12,8"
                                     FontSize="14"
                                     BorderBrush="#DDD" 
                                     BorderThickness="1.5"
                                     Background="#FAFAFA"
                                     VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <!-- Цена -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Цена (руб) *" 
                                       FontWeight="SemiBold" 
                                       Foreground="#444"
                                       FontSize="14"
                                       Margin="0,0,0,8"
                                       TextOptions.TextFormattingMode="Display"/>
                            <TextBox x:Name="txtPrice" 
                                     Height="40" 
                                     Padding="12,8"
                                     FontSize="14"
                                     BorderBrush="#DDD" 
                                     BorderThickness="1.5"
                                     Background="#FAFAFA"
                                     VerticalContentAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- Габариты -->
                    <StackPanel>
                        <TextBlock Text="Габариты (см)" 
                                   FontWeight="SemiBold" 
                                   Foreground="#444"
                                   FontSize="14"
                                   Margin="0,0,0,8"
                                   TextOptions.TextFormattingMode="Display"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Длина -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Длина" 
                                           FontSize="13" 
                                           Foreground="#666"
                                           Margin="0,0,0,5"
                                           TextOptions.TextFormattingMode="Display"/>
                                <TextBox x:Name="txtLength" 
                                         Height="40" 
                                         Padding="12,8"
                                         FontSize="14"
                                         BorderBrush="#DDD" 
                                         BorderThickness="1.5"
                                         Background="#FAFAFA"
                                         VerticalContentAlignment="Center"
                                         Text="0"/>
                            </StackPanel>

                            <!-- Ширина -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Ширина" 
                                           FontSize="13" 
                                           Foreground="#666"
                                           Margin="0,0,0,5"
                                           TextOptions.TextFormattingMode="Display"/>
                                <TextBox x:Name="txtWidth" 
                                         Height="40" 
                                         Padding="12,8"
                                         FontSize="14"
                                         BorderBrush="#DDD" 
                                         BorderThickness="1.5"
                                         Background="#FAFAFA"
                                         VerticalContentAlignment="Center"
                                         Text="0"/>
                            </StackPanel>

                            <!-- Высота -->
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Высота" 
                                           FontSize="13" 
                                           Foreground="#666"
                                           Margin="0,0,0,5"
                                           TextOptions.TextFormattingMode="Display"/>
                                <TextBox x:Name="txtHeight" 
                                         Height="40" 
                                         Padding="12,8"
                                         FontSize="14"
                                         BorderBrush="#DDD" 
                                         BorderThickness="1.5"
                                         Background="#FAFAFA"
                                         VerticalContentAlignment="Center"
                                         Text="0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- Изображение -->
                    <StackPanel>
                        <TextBlock Text="Файл изображения" 
                                   FontWeight="SemiBold" 
                                   Foreground="#444"
                                   FontSize="14"
                                   Margin="0,0,0,8"
                                   TextOptions.TextFormattingMode="Display"/>
                        <TextBox x:Name="txtImgUrl" 
                                 Height="40" 
                                 Padding="12,8"
                                 FontSize="14"
                                 BorderBrush="#DDD" 
                                 BorderThickness="1.5"
                                 Background="#FAFAFA"
                                 VerticalContentAlignment="Center"/>
                        <TextBlock Text="Укажите только имя файла (например: product1.jpg)" 
                                   FontSize="12" 
                                   Foreground="#888"
                                   Margin="0,8,0,0"
                                   TextOptions.TextFormattingMode="Display"/>
                    </StackPanel>

                </StackPanel>

                <!-- Кнопка добавления -->
                <Button Content="➕ Добавить товар" 
                        Click="OnAddClick" 
                        Margin="0,30,0,0"
                        Background="#1976D2"
                        Foreground="White"
                        BorderThickness="0"
                        Height="45"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Padding="0"
                        VerticalContentAlignment="Center"
                        SnapsToDevicePixels="True">
                    <Button.Effect>
                        <DropShadowEffect BlurRadius="8" Opacity="0.2" ShadowDepth="2"/>
                    </Button.Effect>
                </Button>

                <!-- Подсказка -->
                <TextBlock Text="* - обязательные поля" 
                           FontSize="12" 
                           Foreground="#888"
                           HorizontalAlignment="Center"
                           Margin="0,15,0,0"
                           TextOptions.TextFormattingMode="Display"/>

            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>