<Window x:Class="ozon.Views.RegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Регистрация - Складской учет ООО 'Домашний интерьер'" 
        Height="450" 
        Width="860"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="White">

    <Window.Resources>
        <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="CaretBrush" Value="#2E8B57"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#2E8B57"/>
                    <Setter Property="Background" Value="#FFFFFF"/>
                </Trigger>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="BorderBrush" Value="#CD5C5C"/>
                    <Setter Property="ToolTip" 
                            Value="{Binding RelativeSource={RelativeSource Self}, 
                                   Path=(Validation.Errors)[0].ErrorContent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Background" Value="#FAFAFA"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#2E8B57"/>
                    <Setter Property="Background" Value="#FFFFFF"/>
                </Trigger>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="BorderBrush" Value="#CD5C5C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2E8B57"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#26734A"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1E5C3A"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#CCCCCC"/>
                    <Setter Property="Foreground" Value="#666666"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LabelTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="HyperlinkStyle" TargetType="Hyperlink">
            <Setter Property="Foreground" Value="#2E8B57"/>
            <Setter Property="TextDecorations" Value="None"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Background="White" 
                BorderBrush="#E0E0E0" 
                BorderThickness="1"
                CornerRadius="8"
                Margin="30">

            <Grid Margin="25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Заголовок системы -->
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="Регистрация"
                               FontFamily="Segoe UI"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#2E8B57"
                               TextAlignment="Center"/>
                    <TextBlock Text="Складской учет ООО 'Домашний интерьер'"
                               FontFamily="Segoe UI"
                               FontSize="12"
                               Foreground="#666666"
                               TextAlignment="Center"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Область ввода данных -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center">
                    <TextBlock Text="Имя пользователя" 
                               Style="{StaticResource LabelTextStyle}" Width="279"/>

                    <TextBox Name="UsernameInput" 
                             Style="{StaticResource ModernTextBoxStyle}"
                             Width="280"
                             TextChanged="UsernameInput_TextChanged"/>

                    <TextBlock Text="Пароль" 
                               Style="{StaticResource LabelTextStyle}"
                               Margin="0,15,0,0" Width="278"/>

                    <PasswordBox Name="PasswordInput" 
                                 Style="{StaticResource ModernPasswordBoxStyle}"
                                 Width="280"
                                 PasswordChanged="PasswordInput_PasswordChanged"/>
                </StackPanel>

                <!-- Кнопка регистрации -->
                <Button Grid.Row="2" 
                        Content="ЗАРЕГИСТРИРОВАТЬСЯ" 
                        Style="{StaticResource ModernButtonStyle}"
                        Click="Register_Click"
                        Name="RegisterButton"
                        Width="280"
                        Margin="0,20,0,10"/>

                <!-- Ссылка на вход -->
                <TextBlock Grid.Row="3" 
                           TextAlignment="Center"
                           FontFamily="Segoe UI"
                           FontSize="12"
                           Foreground="#666666">
                    Уже есть аккаунт? 
                    <Hyperlink Name="LoginLink" 
                               Click="NavigateLink_Click"
                               Style="{StaticResource HyperlinkStyle}">
                        Войти
                    </Hyperlink>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>