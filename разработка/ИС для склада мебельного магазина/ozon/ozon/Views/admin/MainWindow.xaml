<Window x:Class="ozon.Views.MainAdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ozon.Views"
        mc:Ignorable="d"
        Title="Склад - Панель управления" 
        Height="600" 
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F8F9FA">

    <Grid>
        <!-- Основной контейнер -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" 
                Background="White" 
                Padding="20" 
                BorderBrush="#E1E5E9" 
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Логотип и заголовок -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="СКЛАД" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               Foreground="#2C3E50"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Заголовок -->
                <TextBlock Grid.Column="1" 
                           Text="Панель управления сотрудника" 
                           FontSize="16" 
                           Foreground="#5A6C7D"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <!-- Кнопки управления -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Кнопка отчета по товарам -->
                    <Button x:Name="ExportProductsReportBtn"
                            Content="📈 Товары"
                            Click="OnExportProductsReportClick"
                            ToolTip="Экспорт отчета по товарам в Word"
               
                            Margin="0,0,10,0"
                            Padding="12,6"/>

                    <!-- Кнопка отчета по заказам -->
                    <Button x:Name="ExportOrdersReportBtn"
                            Content="📊 Заказы"
                            Click="OnExportOrdersReportClick"
                            ToolTip="Экспорт отчета по заказам в Word"
                      
                            Margin="0,0,10,0"
                            Padding="12,6"/>

                    <!-- Кнопка назад -->
                    <Button Content="← Назад" 
                            Click="Back_Click"
                            
                            Padding="15,8"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основной контент -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="40" Orientation="Vertical">

                <!-- Приветствие -->
                <TextBlock Text="Добро пожаловать!" 
                           FontSize="28" 
                           FontWeight="Light"
                           Foreground="#2C3E50"
                           Margin="0,0,0,30"/>

                <TextBlock Text="Управление складскими операциями" 
                           FontSize="16" 
                           Foreground="#5A6C7D"
                           Margin="0,0,0,40"/>

                <!-- Карточки функций -->
                <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">

                    <!-- Карточка товаров -->
                    <Border Width="280" 
                            Height="200" 
                            Background="White" 
                            CornerRadius="12" 
                            Margin="0,0,30,30"
                            BorderBrush="#E1E5E9" 
                            BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" 
                                              ShadowDepth="0" 
                                              Opacity="0.1" 
                                              Color="Black"/>
                        </Border.Effect>

                        <Button Click="OnProductsClick" 
                                Background="Transparent" 
                                BorderThickness="0"
                                Padding="0">
                            <StackPanel Orientation="Vertical" 
                                        HorizontalAlignment="Center" 
                                        VerticalAlignment="Center">
                                <Border Background="#E3F2FD" 
                                        Width="60" 
                                        Height="60" 
                                        CornerRadius="30"
                                        Margin="0,0,0,15">
                                    <TextBlock Text="📦" 
                                               FontSize="24" 
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Товары" 
                                           FontSize="18" 
                                           FontWeight="SemiBold" 
                                           Foreground="#2C3E50"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="Управление номенклатурой" 
                                           FontSize="12" 
                                           Foreground="#6C757D" 
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           MaxWidth="200"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <!-- Карточка добавления товара -->
                    <Border Width="280" 
                            Height="200" 
                            Background="White" 
                            CornerRadius="12" 
                            Margin="0,0,30,30"
                            BorderBrush="#E1E5E9" 
                            BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" 
                                              ShadowDepth="0" 
                                              Opacity="0.1" 
                                              Color="Black"/>
                        </Border.Effect>

                        <Button Click="OnAddNewProductClick" 
                                Background="Transparent" 
                                BorderThickness="0"
                                Padding="0">
                            <StackPanel Orientation="Vertical" 
                                        HorizontalAlignment="Center" 
                                        VerticalAlignment="Center">
                                <Border Background="#E8F5E8" 
                                        Width="60" 
                                        Height="60" 
                                        CornerRadius="30"
                                        Margin="0,0,0,15">
                                    <TextBlock Text="➕" 
                                               FontSize="24" 
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Добавить товар" 
                                           FontSize="18" 
                                           FontWeight="SemiBold" 
                                           Foreground="#2C3E50"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="Создание новой позиции" 
                                           FontSize="12" 
                                           Foreground="#6C757D" 
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           MaxWidth="200"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <!-- Карточка поставок -->
                    <Border Width="280" 
                            Height="200" 
                            Background="White" 
                            CornerRadius="12" 
                            Margin="0,0,30,30"
                            BorderBrush="#E1E5E9" 
                            BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" 
                                              ShadowDepth="0" 
                                              Opacity="0.1" 
                                              Color="Black"/>
                        </Border.Effect>

                        <Button Click="OnOrdersClick" 
                                Background="Transparent" 
                                BorderThickness="0"
                                Padding="0">
                            <StackPanel Orientation="Vertical" 
                                        HorizontalAlignment="Center" 
                                        VerticalAlignment="Center">
                                <Border Background="#FFF3E0" 
                                        Width="60" 
                                        Height="60" 
                                        CornerRadius="30"
                                        Margin="0,0,0,15">
                                    <TextBlock Text="🚚" 
                                               FontSize="24" 
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Поставки/отгрузки" 
                                           FontSize="18" 
                                           FontWeight="SemiBold" 
                                           Foreground="#2C3E50"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="История перемещений" 
                                           FontSize="12" 
                                           Foreground="#6C757D" 
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           MaxWidth="200"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <!-- Карточка новой поставки -->
                    <Border Width="280" 
                            Height="200" 
                            Background="White" 
                            CornerRadius="12" 
                            Margin="0,0,30,30"
                            BorderBrush="#E1E5E9" 
                            BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" 
                                              ShadowDepth="0" 
                                              Opacity="0.1" 
                                              Color="Black"/>
                        </Border.Effect>

                        <Button Click="OnAddNewOrdersClick" 
                                Background="Transparent" 
                                BorderThickness="0"
                                Padding="0">
                            <StackPanel Orientation="Vertical" 
                                        HorizontalAlignment="Center" 
                                        VerticalAlignment="Center">
                                <Border Background="#FCE4EC" 
                                        Width="60" 
                                        Height="60" 
                                        CornerRadius="30"
                                        Margin="0,0,0,15">
                                    <TextBlock Text="📋" 
                                               FontSize="24" 
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Новая поставка" 
                                           FontSize="18" 
                                           FontWeight="SemiBold" 
                                           Foreground="#2C3E50"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="Оформить приход/расход" 
                                           FontSize="12" 
                                           Foreground="#6C757D" 
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           MaxWidth="200"/>
                            </StackPanel>
                        </Button>
                    </Border>

                </WrapPanel>

                <!-- Статистика -->
                <Border Background="White" 
                        CornerRadius="12" 
                        Padding="25" 
                        Margin="0,20,0,0"
                        BorderBrush="#E1E5E9" 
                        BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" 
                                          ShadowDepth="0" 
                                          Opacity="0.1" 
                                          Color="Black"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" 
                                Background="#F8F9FA" 
                                Width="40" 
                                Height="40" 
                                CornerRadius="20"
                                Margin="0,0,15,0">
                            <TextBlock Text="📊" 
                                       FontSize="16" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Быстрый доступ" 
                                       FontSize="16" 
                                       FontWeight="SemiBold" 
                                       Foreground="#2C3E50"
                                       Margin="0,0,0,5"/>
                            <TextBlock Text="Все основные функции управления складом в одном месте" 
                                       FontSize="12" 
                                       Foreground="#6C757D"/>
                        </StackPanel>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Подвал -->
        <Border Grid.Row="2" 
                Background="White" 
                Padding="15" 
                BorderBrush="#E1E5E9" 
                BorderThickness="1,0,0,0">
            <TextBlock Text="Складская система управления • v1.0" 
                       FontSize="12" 
                       Foreground="#6C757D" 
                       HorizontalAlignment="Center"/>
        </Border>

    </Grid>

    <!-- Стили -->
    <Window.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center" 
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F3F4F6"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#9CA3AF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
</Window>