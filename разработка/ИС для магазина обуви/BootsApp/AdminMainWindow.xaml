<Window x:Class="BootsApp.AdminMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BootsApp"
        mc:Ignorable="d"
        Title="Окно пользователей системы" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="83*"/>
            <RowDefinition Height="351*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="89*"/>
            <ColumnDefinition Width="311*"/>
        </Grid.ColumnDefinitions>
        <Image HorizontalAlignment="Left" Height="46" VerticalAlignment="Center" Width="45" Source="/Icon.png" Margin="10,0,0,0"/>
        <Label Content="Магазин Ботинок" HorizontalAlignment="Left" Margin="60,0,0,0" VerticalAlignment="Center" Height="25" Width="112"/>
        <StackPanel Grid.Row="1">
            <Button Content="Товары" Click="AdminTovarButt"/>
            <Button Content="Заказы" Margin="0,5,0,0" Click="AdminOrderBuut"/>
        </StackPanel>
        <Button Content="Выход" HorizontalAlignment="Center" Margin="0,306,0,0" Grid.Row="1" VerticalAlignment="Top" Width="158" Click="GoHomeButt"/>
        <DataGrid x:Name="DgUser" Margin="5,46,10,62" Grid.Column="1" Grid.Row="1" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn  Header="id" Binding="{Binding id}"/>
                <DataGridTextColumn  Header="роль" Binding="{Binding роли.Роль}"/>
                <DataGridTextColumn  Header="ФИО" Binding="{Binding ФИО}"/>
                <DataGridTextColumn  Header="Логин" Binding="{Binding Логин}"/>
                <DataGridTextColumn  Header="Пароль" Binding="{Binding Пароль}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
        <Button Grid.Column="1" Content="Добавить" HorizontalAlignment="Left" Margin="10,306,0,0" Grid.Row="1" VerticalAlignment="Top" Width="72" Click="AddButt"/>
        <Button Grid.Column="1" Content="Изменить" HorizontalAlignment="Left" Margin="102,306,0,0" Grid.Row="1" VerticalAlignment="Top" Width="78" Click="ChangeButt"/>
        <Button Grid.Column="1" Content="Обновить" HorizontalAlignment="Left" Margin="428,306,0,0" Grid.Row="1" VerticalAlignment="Top"  Width="72" Click="RefreshButt"/>
        <Button Grid.Column="1" Content="Удалить" HorizontalAlignment="Left" Margin="526,306,0,0" Grid.Row="1" VerticalAlignment="Top"  Width="68" Click="DelButt"/>
        <Label Grid.Column="1" Content="Поиск" HorizontalAlignment="Left" Margin="20,5,0,0" Grid.Row="1" VerticalAlignment="Top" Height="27"/>
        <TextBox x:Name="SearchBox" Grid.Column="1" HorizontalAlignment="Left" Margin="74,10,0,0" Grid.Row="1" TextWrapping="Wrap" VerticalAlignment="Top" Width="180" TextChanged="TextBox_TextChanged"/>

    </Grid>
</Window>
