<Window x:Class="BootsApp.AdminOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BootsApp"
        mc:Ignorable="d"
        Title="Окно заказов" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="83*"/>
            <RowDefinition Height="351*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="89*"/>
            <ColumnDefinition Width="311*"/>
        </Grid.ColumnDefinitions>
        <Image HorizontalAlignment="Left" Height="46" VerticalAlignment="Center" Width="45" Source="/Icon.png" Margin="10,0,0,0"/>
        <Label Content="Магазин Ботинок" HorizontalAlignment="Left" Margin="60,0,0,0" VerticalAlignment="Center" Height="25" Width="112"/>
        <StackPanel Grid.Row="1">
            <Button Content="Товары" Click="AdminTovarButt"/>
            <Button Content="Пользователи" Margin="0,5,0,0" Click="AdminUsersButt" />
        </StackPanel>
        <Button Content="Выход" HorizontalAlignment="Center" Margin="0,306,0,0" Grid.Row="1" VerticalAlignment="Top" Width="158" Click="GoHomeButt"/>
        <DataGrid x:Name="DgOrder" Margin="5,83,25,65" Grid.Column="1" AutoGenerateColumns="False" Grid.RowSpan="2">
            <DataGrid.Columns>
                <DataGridTextColumn  Header="id" Binding="{Binding id}"/>
                <DataGridTextColumn x:Name="Дата_заказа"   Header="Дата заказа" Binding="{Binding Дата_заказа, StringFormat='dd.MM.yyyy'}"/>
                <DataGridTextColumn x:Name="Дата_доставки"  Header="Дата доставки" Binding="{Binding Дата_доставки, StringFormat='dd.MM.yyyy'}"/>
                <DataGridTextColumn x:Name="Адрес" Header="Адрес" Binding="{Binding Пункты_выдачи_import.ПолныйАдрес}"/>
                <DataGridTextColumn x:Name="ФИО"   Header="ФИО клиента" Binding="{Binding ФИО_авторизованного_клиента}"/>
                <DataGridTextColumn x:Name="Код" Header="Код для получения" Binding="{Binding Код_для_получения}"/>
                <DataGridTextColumn x:Name="Статус" Header="Статус" Binding="{Binding Статусы.название}"/>
            </DataGrid.Columns>
        </DataGrid>
        <Button Grid.Column="1" Content="Добавить" HorizontalAlignment="Left" Margin="6,306,0,0" Grid.Row="1" VerticalAlignment="Top" Width="72" Click="AddButt"/>
        <Button Grid.Column="1" Content="Изменить" HorizontalAlignment="Left" Margin="98,306,0,0" Grid.Row="1" VerticalAlignment="Top" Width="78" Click="ChangeButt"/>
        <Button Grid.Column="1" Content="Обновить" HorizontalAlignment="Left" Margin="424,306,0,0" Grid.Row="1" VerticalAlignment="Top"  Width="72" Click="RefreshButt"/>
        <Button Grid.Column="1" Content="Удалить" HorizontalAlignment="Left" Margin="522,306,0,0" Grid.Row="1" VerticalAlignment="Top"  Width="68" Click="DelButt"/>
        <Label Grid.Column="1" Content="Поиск" HorizontalAlignment="Left" Margin="24,31,0,0" VerticalAlignment="Top" Height="27"/>
        <TextBox x:Name="SearchBox" Grid.Column="1" HorizontalAlignment="Left" Margin="84,36,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="180" TextChanged="TextBox_TextChanged"/>

    </Grid>
</Window>

