<Window x:Class="ozon.Views.ChangeStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ozon.Views"
        mc:Ignorable="d"
        Title="Изменение статуса заказа" Height="450" Width="500"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <Border Background="White" Margin="20" CornerRadius="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.15" ShadowDepth="3" Color="Black"/>
        </Border.Effect>

        <StackPanel Margin="30" >

            <!-- Заголовок -->
            <TextBlock Text="🔄 Изменение статуса заказа" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       Foreground="#2C3E50"
                       HorizontalAlignment="Center"
                       TextOptions.TextFormattingMode="Display"
                       TextAlignment="Center"
                       Margin="0,0,0,15"/>

            <!-- Выбор статуса -->
            <StackPanel Margin="0,0,0,15">
                <TextBlock Text="Выберите новый статус *" 
                           FontSize="15" 
                           FontWeight="SemiBold" 
                           Foreground="#495057"
                           Margin="0,0,0,8"
                           TextOptions.TextFormattingMode="Display"/>
                <ComboBox Name="comboBox" 
                          ItemsSource="{Binding Statuses}" 
                          SelectedValue="{Binding SelectedStatus}"
                          Height="45" 
                          Padding="15,0"
                          FontSize="14"
                          BorderBrush="#D1D5DB" 
                          BorderThickness="2"
                          Background="#FFFFFF"
                          VerticalContentAlignment="Center"
                          SnapsToDevicePixels="True"
                          VerticalAlignment="Center"
                          SelectionChanged="ComboBox_SelectionChanged">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" 
                                       FontSize="14" 
                                       Padding="5,8"
                                       TextOptions.TextFormattingMode="Display"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <!-- Поле расположения на складе -->
            <StackPanel x:Name="LocationPanel" 
                        Visibility="Collapsed"
                        Margin="0,0,0,15">
                <TextBlock Text="Расположение на складе *" 
                           FontSize="15" 
                           FontWeight="SemiBold" 
                           Foreground="#495057"
                           Margin="0,0,0,8"
                           TextOptions.TextFormattingMode="Display"/>
                <TextBox x:Name="LocationTextBox"
                         Text="{Binding Location, UpdateSourceTrigger=PropertyChanged}"
                         Height="45" 
                         Padding="15,0"
                         FontSize="14"
                         BorderBrush="#D1D5DB" 
                         BorderThickness="2"
                         Background="#FFFFFF"
                         VerticalContentAlignment="Center"
                         SnapsToDevicePixels="True"
                         VerticalAlignment="Center"
                 />
            </StackPanel>

            <!-- Кнопки -->
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Center" 
                        Margin="0,20,0,0">
                <Button Content="✅ Применить изменения" 
                        Click="Apply_Click"
                        Height="48"
                        Background="#10B981"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Padding="25,0"
                        MinWidth="140"
                        Cursor="Hand"
                        VerticalAlignment="Center">
                    <Button.Effect>
                        <DropShadowEffect BlurRadius="12" Opacity="0.25" ShadowDepth="3" Color="#10B981"/>
                    </Button.Effect>
                </Button>

                <Button Content="❌ Отменить" 
                        Click="Cancel_Click"
                        Height="48"
                        Background="#6B7280"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Padding="25,0"
                        MinWidth="120"
                        Cursor="Hand"
                        VerticalAlignment="Center"
                        Margin="15,0,0,0">
                    <Button.Effect>
                        <DropShadowEffect BlurRadius="12" Opacity="0.25" ShadowDepth="3" Color="#6B7280"/>
                    </Button.Effect>
                </Button>
            </StackPanel>

            <!-- Подсказка -->
            <TextBlock Text="* - обязательное поле" 
                       FontSize="12" 
                       Foreground="#9CA3AF"
                       HorizontalAlignment="Center"
                       Margin="0,15,0,0"
                       TextOptions.TextFormattingMode="Display"/>

        </StackPanel>
    </Border>
</Window>